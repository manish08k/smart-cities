# ═══════════════════════════════════════════════════════════════════════════════
#  AutoFlow — Operator Environment Configuration
#
#  HOW IT WORKS (like n8n):
#    1. Operator registers OAuth apps ONCE on each provider's developer console
#       and puts the client_id/secret here.
#    2. End-users never see these values. They just click "Connect" in the UI,
#       go through the provider's OAuth consent screen, and AutoFlow stores
#       their encrypted token automatically.
#    3. WhatsApp & Telegram use long-lived tokens — operator sets them once here.
# ═══════════════════════════════════════════════════════════════════════════════

# ── App
APP_ENV=production
APP_BASE_URL=https://your-domain.com
APP_SECRET_KEY=CHANGE_ME_64_CHAR_HEX
CREDENTIAL_ENCRYPTION_KEY=CHANGE_ME_32_CHAR_KEY

# ── Database
POSTGRES_PASSWORD=autoflow_secret

# ── Redis
REDIS_PASSWORD=redis_secret

# ── Flower
FLOWER_USER=admin
FLOWER_PASSWORD=change_me

# ── Google (https://console.cloud.google.com/apis/credentials)
# Redirect URI: https://your-domain.com/oauth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Slack (https://api.slack.com/apps)
# Redirect URI: https://your-domain.com/oauth/callback/slack
# Events URL:   https://your-domain.com/webhooks/slack/events
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# ── GitHub (https://github.com/settings/applications/new)
# Redirect URI: https://your-domain.com/oauth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Notion (https://www.notion.so/my-integrations)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# ── Discord (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=

# ── HubSpot (https://developers.hubspot.com/)
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# ── Airtable (https://airtable.com/create/oauth)
AIRTABLE_CLIENT_ID=
AIRTABLE_CLIENT_SECRET=

# ── WhatsApp Meta Cloud API (https://developers.facebook.com/apps/)
# Webhook URL: https://your-domain.com/webhooks/whatsapp/inbound
WHATSAPP_APP_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=autoflow_whatsapp_verify

# ── Telegram (create bot via @BotFather)
# Webhook URL: https://your-domain.com/webhooks/telegram/inbound
TELEGRAM_BOT_TOKEN=

# ── SMTP fallback
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
